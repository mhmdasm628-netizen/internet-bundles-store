{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Service categories (e.g., Vodafone, Orange, Etisalat)",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Category name" },
        "icon": { "type": "string", "description": "Icon name or URL" },
        "order": { "type": "number", "description": "Display order" }
      },
      "required": ["name"]
    },
    "Package": {
      "title": "Package",
      "description": "Internet packages available for purchase",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Package name" },
        "description": { "type": "string", "description": "Package details" },
        "price": { "type": "number", "description": "Price in EGP" },
        "imageUrl": { "type": "string", "description": "Direct image URL" },
        "categoryId": { "type": "string", "description": "ID of the category" },
        "speed": { "type": "string", "description": "Speed details" },
        "quota": { "type": "string", "description": "Quota details" },
        "stock": { "type": "number", "description": "Available quantity" },
        "isActive": { "type": "boolean", "description": "Whether the package is visible" }
      },
      "required": ["name", "price", "categoryId"]
    },
    "User": {
      "title": "User",
      "description": "Application users and their roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "enum": ["admin", "moderator", "user"], "description": "User role" }
      },
      "required": ["uid", "email", "role"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User subscription requests",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID" },
        "userEmail": { "type": "string", "description": "User email" },
        "packageId": { "type": "string", "description": "Package ID" },
        "packageName": { "type": "string", "description": "Package name at time of purchase" },
        "price": { "type": "number", "description": "Price paid" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "refund_requested", "refunded"], "description": "Current status" },
        "senderPhone": { "type": "string", "description": "Vodafone Cash number used to send" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "packageId", "status", "senderPhone"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Messages between user and admin for a subscription",
      "type": "object",
      "properties": {
        "subscriptionId": { "type": "string", "description": "Subscription ID" },
        "senderId": { "type": "string", "description": "User ID of sender" },
        "text": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subscriptionId", "senderId", "text"]
    },
    "RefundRequest": {
      "title": "RefundRequest",
      "description": "Details for refunding a subscription",
      "type": "object",
      "properties": {
        "subscriptionId": { "type": "string", "description": "Subscription ID" },
        "senderPhone": { "type": "string", "description": "Phone number used for initial payment" },
        "refundPhone": { "type": "string", "description": "Phone number to receive the refund" },
        "reason": { "type": "string", "description": "Reason for refund" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subscriptionId", "senderPhone", "refundPhone"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global app settings",
      "type": "object",
      "properties": {
        "vodafoneCashNumber": { "type": "string", "description": "The number users send money to" },
        "isMaintenanceMode": { "type": "boolean", "description": "Whether the site is paused for purchases" }
      }
    }
  },
  "firestore": {
    "categories": { "schema": "Category", "description": "Service categories" },
    "packages": { "schema": "Package", "description": "Internet packages" },
    "subscriptions": { "schema": "Subscription", "description": "User subscription requests" },
    "chatMessages": { "schema": "ChatMessage", "description": "Chat messages for active subscriptions" },
    "refundRequests": { "schema": "RefundRequest", "description": "Refund request details" },
    "settings": { "schema": "Settings", "description": "Global configuration" }
  }
}
