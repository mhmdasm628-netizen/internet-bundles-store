rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "mhmdasm628@gmail.com" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "djcj1421@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isModerator() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator') ||
        isAdmin()
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Packages
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Subscriptions
    match /subscriptions/{subId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isModerator());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (isAdmin() && (request.resource.data.status == 'approved' || request.resource.data.status == 'refunded' || request.resource.data.status == 'rejected' || request.resource.data.status == 'refund_requested')) ||
        (isModerator() && !isAdmin() && (request.resource.data.status == 'refund_requested' || request.resource.data.status == 'rejected'))
      );
    }

    // Chat Messages
    match /chatMessages/{msgId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid || 
        isModerator() ||
        exists(/databases/$(database)/documents/subscriptions/$(resource.data.subscriptionId)) && 
        get(/databases/$(database)/documents/subscriptions/$(resource.data.subscriptionId)).data.userId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        (isModerator() && get(/databases/$(database)/documents/subscriptions/$(request.resource.data.subscriptionId)).data.status == 'approved') || 
        (get(/databases/$(database)/documents/subscriptions/$(request.resource.data.subscriptionId)).data.userId == request.auth.uid && 
         get(/databases/$(database)/documents/subscriptions/$(request.resource.data.subscriptionId)).data.status == 'approved')
      );
    }

    // Refund Requests
    match /refundRequests/{requestId} {
      allow read: if isModerator();
      allow create: if isModerator();
      allow update: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isModerator();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
